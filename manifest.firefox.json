{
  "manifest_version": 3,
  "name": "GitHeron",
  "description": "Highlight web pages and sync annotations directly to a GitHub repository.",
  "version": "0.1.2",
  "action": {
    "default_title": "GitHeron"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://api.github.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "githeron@chenyukang.github.io",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "authenticationInfo",
          "websiteActivity",
          "websiteContent"
        ]
      }
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "content/content-style.css"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ]
    }
  ],
  "background": {
    "scripts": [
      "browser-polyfill.js",
      "background/service-worker.js"
    ]
  },
  "sidebar_action": {
    "default_title": "GitHeron",
    "default_panel": "sidepanel/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "css": [
        "content/content-style.css"
      ],
      "js": [
        "browser-polyfill.js",
        "vendor/defuddle/defuddle.full.js",
        "content/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
